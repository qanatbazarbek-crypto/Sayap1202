#include <MeMCore.h>
MeDCMotor motorLeft(M1);
MeDCMotor motorRight(M2);
MeUltrasonicSensor sonar(PORT_3);
MeLineFollower line(PORT_2);
MeRGBLed led(7, 2);
MeBuzzer buzzer;
bool running = false;
int lastDir = 1;
unsigned long lastTime = 0;
unsigned long lastSonar = 0;
void drive(int leftSpeed, int rightSpeed) {
motorLeft.run(-leftSpeed);
motorRight.run(rightSpeed);
}
void avoid() {
led.setColor(255, 0, 0);
led.show();
drive(-120, 120);
delay(400);
drive(120, 120);
delay(700);
drive(120, -120);
delay(500);
drive(100, 100);
unsigned long t = millis();
while(line.readSensors() == 3) {
if(millis() - t > 2000) break;
}
}
void setup() {
led.setpin(7);
drive(0, 0);
}
void loop() {
int sensorState = line.readSensors();
int distance = sonar.distanceCm();
unsigned long ms = millis();
if (!running) {
if (sensorState != 3) {
running = true;
} else {
drive(0, 0);
led.setColor(0, 0, 255);
led.show();
return;
}
}
if (ms - lastSonar > 60) {
lastSonar = ms;
if (distance > 48 && distance < 52) buzzer.tone(500, 50);
else if (distance > 23 && distance < 27) buzzer.tone(1000, 50);
else if (distance > 15 && distance < 19) buzzer.tone(1500, 50);
}
if (distance > 0 && distance < 15) {
avoid();
return;
}
led.setColor(0, 255, 0);
led.show();
if (sensorState == 0) {
drive(120, 120);
lastDir = 0;
lastTime = ms;
} else if (sensorState == 1) {
drive(40, 120);
lastDir = 1;
lastTime = ms;
} else if (sensorState == 2) {
drive(120, 40);
lastDir = 2;
lastTime = ms;
} else if (sensorState == 3) {
if (lastDir == 1) {
drive(100, -100);
} else if (lastDir == 2) {
drive(-100, 100);
} else {
if (ms - lastTime > 200) {
led.setColor(255, 255, 0);
led.show();
drive(-120, 120);
} else {
drive(100, 100);
}
}
}
}
