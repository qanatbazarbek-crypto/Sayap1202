#include <MeMCore.h>
MeDCMotor motorLeft(M1);
MeDCMotor motorRight(M2);
MeUltrasonicSensor sonar(PORT_3);
MeLineFollower line(PORT_2);
MeRGBLed led(7, 2);
MeBuzzer buzzer;
MeIR ir;
bool runRobot = false;
int lastDir = 1;
int mode = 1;
unsigned long lastTurn = 0, lastSonar = 0;
void drive(int leftSpeed, int rightSpeed) {
motorLeft.run(-leftSpeed);
motorRight.run(rightSpeed);
}
void avoid() {
led.setColor(255, 0, 0); led.show();
drive(-120, 120); delay(400);
drive(120, 120); delay(700);
drive(120, -120); delay(500);
drive(100, 100);
unsigned long tm = millis();
while(line.readSensors() == 3 && millis() - tm < 2000);
}
void setup() {
Serial.begin(115200);
ir.begin();
led.setpin(7);
drive(0, 0);
}
void loop() {
char cmd = 0;
unsigned long ms = millis();
if (Serial.available()) cmd = Serial.read();
ir.loop();
int irCode = ir.getCode();
if (irCode == 69) cmd = 'A';
if (irCode == 70) cmd = 'M';
if (irCode == 64) cmd = 'F';
if (irCode == 25) cmd = 'B';
if (irCode == 7) cmd = 'L';
if (irCode == 9) cmd = 'R';
if (irCode == 21) cmd = 'S';
if (cmd == 'A') mode = 1;
else if (cmd == 'M') { mode = 0; drive(0, 0); led.setColor(0, 0, 0); led.show(); }
if (mode == 1) {
int sensorState = line.readSensors();
int distance = sonar.distanceCm();
if (!runRobot) {
if (sensorState != 3) runRobot = true;
else { drive(0, 0); led.setColor(0, 0, 255); led.show(); return; }
}
if (ms - lastSonar > 60) {
lastSonar = ms;
if (distance > 48 && distance < 52) buzzer.tone(500, 50);
else if (distance > 23 && distance < 27) buzzer.tone(1000, 50);
else if (distance > 15 && distance < 19) buzzer.tone(1500, 50);
}
if (distance > 0 && distance < 15) { avoid(); return; }
led.setColor(0, 255, 0); led.show();
switch(sensorState) {
case 0: drive(120, 120); lastDir = 0; lastTurn = ms; break;
case 1: drive(40, 120); lastDir = 1; lastTurn = ms; break;
case 2: drive(120, 40); lastDir = 2; lastTurn = ms; break;
case 3:
if (lastDir == 1) drive(100, -100);
else if (lastDir == 2) drive(-100, 100);
else if (ms - lastTurn > 200) { led.setColor(255, 255, 0); led.show(); drive(-120, 120); }
else drive(100, 100);
break;
}
} else {
if (cmd == 'F') drive(120, 120);
else if (cmd == 'B') drive(-120, -120);
else if (cmd == 'L') drive(-100, 100);
else if (cmd == 'R') drive(100, -100);
else if (cmd == 'S') drive(0, 0);
}
}
